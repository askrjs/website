{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "jsx": "react-jsx",
    "jsxImportSource": "@askrjs/askr",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": ["ssg.config.ts", "src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts"]
}
