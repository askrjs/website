# Normalize line endings for text files in the repository
* text=auto eol=lf

# Common text source files
*.ts text
*.tsx text
*.js text
*.mjs text
*.cjs text
*.json text
*.md text
*.css text
*.html text
*.yml text
*.yaml text
*.sh text eol=lf

# Windows-specific scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
