{
  "name": "@askrjs/website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Askr framework website and docs",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:client && npm run build:ssg && npm run build:ssr",
    "build:client": "vite build",
    "build:ssg": "tsx --tsconfig ./tsconfig.ssg.json ./scripts/build-site.ts",
    "build:ssr": "vite build --ssr src/server/entry-server.tsx --outDir dist/server",
    "build:incremental": "npm run build:client && tsx --tsconfig ./tsconfig.ssg.json ./scripts/build-site.ts --incremental",
    "lint": "eslint src scripts ssg.config.ts vite.config.ts --ext .ts,.tsx",
    "fmt": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run build",
    "serve": "npx serve dist -l 4173",
    "start": "npm run build && npx serve dist -l 4173"
  },
  "dependencies": {
    "@askrjs/askr": "file:../askr",
    "@askrjs/askr-themes": "file:../askr-themes",
    "@askrjs/askr-ui": "file:../askr-ui",
    "esbuild": "^0.27.4",
    "vite": "^8.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "tsx": {
    "tsconfig": "./tsconfig.ssg.json"
  }
}
