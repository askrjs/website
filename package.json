{
  "name": "@askrjs/website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Askr framework website and docs",
  "scripts": {
    "build": "tsx ./scripts/build-site.ts",
    "build:incremental": "tsx ./scripts/build-site.ts --incremental",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run build",
    "serve": "npx serve dist -l 4173"
  },
  "dependencies": {
    "@askrjs/askr-themes": "github:askrjs/askr-themes#main",
    "@askrjs/askr-ui": "github:askrjs/askr-ui#main"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
