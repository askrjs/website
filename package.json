{
  "name": "@askrjs/website",
  "version": "0.1.0",
  "private": true,
  "description": "Askr marketing and documentation site",
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "npm run docs:drift && npm run build:client && npm run build:ssg",
    "build:client": "vp build --outDir .askr/client",
    "build:ssg": "askr ssg --config ./ssg.config.ts --output ./dist && cp ./dist/404/index.html ./dist/404.html && node ./scripts/generate-sitemap.mjs",
    "verify:static": "node ./scripts/verify-static-output.mjs",
    "docs:api": "node ./scripts/generate-api-snapshot.mjs",
    "docs:api:check": "node ./scripts/generate-api-snapshot.mjs --check",
    "docs:cli": "node ./scripts/generate-cli-reference.mjs",
    "docs:cli:check": "node ./scripts/generate-cli-reference.mjs --check",
    "docs:manifest": "tsx ./scripts/generate-docs-manifest.ts",
    "docs:manifest:check": "tsx ./scripts/generate-docs-manifest.ts --check",
    "docs:drift": "npm run docs:api:check && npm run docs:cli:check && npm run docs:manifest:check",
    "lint": "vp lint src scripts ssg.config.ts vite.config.ts",
    "fmt": "vp fmt .",
    "fmt:check": "vp fmt . --check",
    "test:unit": "vp test run",
    "test": "npm run test:unit && npm run verify:static",
    "typecheck": "tsc --noEmit",
    "check": "npm run fmt:check && npm run lint && npm run typecheck && npm run docs:drift && npm run test:unit && npm run build && npm run verify:static",
    "preview": "vp preview --outDir dist"
  },
  "dependencies": {
    "@askrjs/askr": "0.0.55",
    "@askrjs/charts": "0.1.2",
    "@askrjs/fetch": "0.0.1",
    "@askrjs/i18n": "0.0.2",
    "@askrjs/logos": "0.0.4",
    "@askrjs/lucide": "0.0.4",
    "@askrjs/monaco": "0.0.2",
    "@askrjs/otel": "0.0.2",
    "@askrjs/themes": "0.0.13",
    "@askrjs/ui": "0.0.13",
    "@fontsource-variable/domine": "^5.2.8"
  },
  "devDependencies": {
    "@askrjs/auth": "0.0.3",
    "@askrjs/cli": "0.0.3",
    "@askrjs/node": "0.0.3",
    "@askrjs/schema": "0.0.2",
    "@askrjs/server": "0.0.3",
    "@askrjs/vite": "0.0.7",
    "@types/node": "^25.9.3",
    "tsx": "4.23.1",
    "typescript": "^6.0.3",
    "vite-plus": "^0.2.4"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
