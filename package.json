{
  "name": "@askrjs/website",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal Askr static site",
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "npm run build:client && npm run build:ssg",
    "build:client": "vp build --outDir .askr/client",
    "build:ssg": "askr ssg --config ./ssg.config.ts --output ./dist",
    "verify:static": "node ./scripts/verify-static-output.mjs",
    "lint": "vp lint src scripts ssg.config.ts vite.config.ts",
    "fmt": "vp fmt .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run build && npm run verify:static",
    "preview": "vp preview --outDir dist"
  },
  "dependencies": {
    "@askrjs/askr": ">=0.0.54 <0.1.0"
  },
  "devDependencies": {
    "@askrjs/cli": ">=0.0.3 <0.1.0",
    "@askrjs/vite": ">=0.0.6 <0.1.0",
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3",
    "vite-plus": "^0.2.4"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
