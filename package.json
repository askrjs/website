{
  "name": "@askrjs/website",
  "version": "0.1.0",
  "private": true,
  "description": "Askr framework website and docs",
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "npm run build:client && npm run build:ssr && npm run generate",
    "build:client": "vp build",
    "build:ssg": "npm run generate",
    "generate": "tsx --tsconfig ./tsconfig.ssg.json ./scripts/ssg-build.ts",
    "build:ssr": "vp build --ssr --outDir dist/server",
    "build:incremental": "npm run build:client && tsx --tsconfig ./tsconfig.ssg.json ./scripts/ssg-build.ts --incremental",
    "verify:static": "tsx --tsconfig ./tsconfig.ssg.json ./scripts/verify-static-output.ts",
    "lint": "vp lint src scripts ssg.config.ts vite.config.ts",
    "fmt": "vp fmt .",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run build && npm run verify:static",
    "preview": "vp preview",
    "serve": "vp preview --host 0.0.0.0 --port 4173",
    "start": "npm run build && npm run preview"
  },
  "dependencies": {
    "@askrjs/askr": "^0.0.43",
    "@askrjs/logos": "^0.0.1",
    "@askrjs/lucide": "^0.0.3",
    "@askrjs/themes": "^0.0.7",
    "@askrjs/ui": "^0.0.10",
    "@askrjs/vite": "^0.0.4"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite-plus": "latest"
  },
  "tsx": {
    "tsconfig": "./tsconfig.ssg.json"
  }
}
